# Copy to `.env` and fill in. .env is gitignored.

# --- Snowflake connection ---------------------------------------------------
# Account identifier. Either the new "<org>-<account>" form or the legacy
# "<account>.<region>.<cloud>" form. Find it in Snowsight: bottom-left, click
# the account name -> "Copy account identifier".
SNOWFLAKE_ACCOUNT=myorg-myaccount

# Username the public key was registered against (ALTER USER ... SET RSA_PUBLIC_KEY=...)
SNOWFLAKE_USER=xren

# Path (absolute or repo-relative) to the unencrypted .p8 private key.
SNOWFLAKE_PRIVATE_KEY_PATH=api_key/xren_private_key.p8

# Optional: passphrase if your .p8 is encrypted. Leave blank if unencrypted.
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Optional but strongly recommended -- pinning these avoids surprises.
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

